<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ManageAlbumsApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Label
                Text="Manage Albums"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <HorizontalStackLayout Padding="30,0" Spacing="25">
                <VerticalStackLayout Spacing="25">
                    <Label Text="Add a new Album:" SemanticProperties.HeadingLevel="Level2"/>

                    <HorizontalStackLayout Spacing="15">
                        <Label Text="Title:" HorizontalOptions="Start" VerticalOptions="Center"/>
                        <Entry x:Name="TitleEntry" HorizontalOptions="End" MinimumWidthRequest="200"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15">
                        <Label Text="Band/artist:" HorizontalOptions="Start" VerticalOptions="Center"/>
                        <Entry x:Name="BandEntry" HorizontalOptions="End" MinimumWidthRequest="200"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15">
                        <Label Text="Year produced:" HorizontalOptions="Start" VerticalOptions="Center"/>
                        <Entry x:Name="YearProducedEntry" HorizontalOptions="End" MinimumWidthRequest="200"/>
                    </HorizontalStackLayout>

                    <Button
                         x:Name="AddAlbumBtn"
                         Text="Add album" 
                         SemanticProperties.Hint="Add this album to the Album list"
                         Clicked="OnAddAlbumClicked"
                         HorizontalOptions="Start" />

                    <Label HeightRequest="35"/>

                    <Label x:Name="ResultsLabel" HorizontalOptions="Start"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="25">
                    <Label Text="View albums:" SemanticProperties.HeadingLevel="Level2" />

                    <Editor x:Name="AllAlbumsEditor"
                            HeightRequest="250" WidthRequest="550" IsEnabled="False" />

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Button 
                            x:Name="ShowAlbumsByYearBtn"
                            Text="Show albums by year" 
                            SemanticProperties.Hint="Shows all the albums by year"
                            Clicked="OnShowAlbumsByYearBtnClicked"
                            HorizontalOptions="Start" />

                        <Entry x:Name="AlbumByYearProducedEntry"
                                   Placeholder="Enter year" MinimumWidthRequest="20"/>

                        <Label WidthRequest="150"/>

                        <Button 
                            x:Name="ShowAlbumsBtn"
                            Text="Show albums" 
                            SemanticProperties.Hint="Shows all the currently albums"
                            Clicked="OnShowAlbumsBtnClicked"
                            HorizontalOptions="End" />
                    </HorizontalStackLayout>

                    

                </VerticalStackLayout>

            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
